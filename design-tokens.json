  "typography": {
    "families": {
      "regular": "Inter_400Regular",
      "medium": "Inter_500Medium",
      "bold": "Inter_700Bold",
      "display": "PlusJakartaSans_700Bold"
    },
    "styles": {
      "displayLarge": {
        "fontFamily": "{typography.families.display}",
        "lineHeight": "64",
        "fontSize": "57",
        "letterSpacing": "0",
        "fontWeight": "700"
      },
      "displayMedium": {
        "fontFamily": "{typography.families.display}",
        "lineHeight": "52",
        "fontSize": "45",
        "letterSpacing": "0",
        "fontWeight": "700"
      },
      "displaySmall": {
        "fontFamily": "{typography.families.display}",
        "lineHeight": "44",
        "fontSize": "36",
        "letterSpacing": "0",
        "fontWeight": "700"
      },
      "headlineLarge": {
        "fontFamily": "{typography.families.display}",
        "lineHeight": "40",
        "fontSize": "32",
        "letterSpacing": "0",
        "fontWeight": "700"
      },
      "headlineMedium": {
        "fontFamily": "{typography.families.display}",
        "lineHeight": "36",
        "fontSize": "28",
        "letterSpacing": "0",
        "fontWeight": "700"
      },
      "headlineSmall": {
        "fontFamily": "{typography.families.display}",
        "lineHeight": "32",
        "fontSize": "24",
        "letterSpacing": "0",
        "fontWeight": "700"
      },
      "titleLarge": {
        "fontFamily": "{typography.families.medium}",
        "lineHeight": "28",
        "fontSize": "22",
        "letterSpacing": "0",
        "fontWeight": "500"
      },
      "titleMedium": {
        "fontFamily": "{typography.families.medium}",
        "lineHeight": "24",
        "fontSize": "16",
        "letterSpacing": "0.15",
        "fontWeight": "500"
      },
      "titleSmall": {
        "fontFamily": "{typography.families.medium}",
        "lineHeight": "20",
        "fontSize": "14",
        "letterSpacing": "0.1",
        "fontWeight": "500"
      },
      "labelLarge": {
        "fontFamily": "{typography.families.medium}",
        "lineHeight": "20",
        "fontSize": "14",
        "letterSpacing": "0.1",
        "fontWeight": "500"
      },
      "labelMedium": {
        "fontFamily": "{typography.families.medium}",
        "lineHeight": "16",
        "fontSize": "12",
        "letterSpacing": "0.5",
        "fontWeight": "500"
      },
      "labelSmall": {
        "fontFamily": "{typography.families.medium}",
        "lineHeight": "16",
        "fontSize": "11",
        "letterSpacing": "0.5",
        "fontWeight": "500"
      },
      "bodyLarge": {
        "fontFamily": "{typography.families.regular}",
        "lineHeight": "24",
        "fontSize": "16",
        "letterSpacing": "0.15",
        "fontWeight": "400"
      },
      "bodyMedium": {
        "fontFamily": "{typography.families.regular}",
        "lineHeight": "20",
        "fontSize": "14",
        "letterSpacing": "0.25",
        "fontWeight": "400"
      },
      "bodySmall": {
        "fontFamily": "{typography.families.regular}",
        "lineHeight": "16",
        "fontSize": "12",
        "letterSpacing": "0.4",
        "fontWeight": "400"
      }
    }
  },
  "spacing": {
    "base": "4",
    "scale": {
      "none": "0",
      "xxs": "{spacing.base}",
      "xs": "calc({spacing.base} * 2)",
      "sm": "calc({spacing.base} * 3)",
      "md": "calc({spacing.base} * 4)",
      "lg": "calc({spacing.base} * 6)",
      "xl": "calc({spacing.base} * 8)",
      "xxl": "calc({spacing.base} * 12)"
    },
    "layout": {
      "screenPadding": "calc({spacing.base} * 4)",
      "sectionSpacing": "calc({spacing.base} * 6)",
      "contentSpacing": "calc({spacing.base} * 4)",
      "cardPadding": "calc({spacing.base} * 4)",
      "buttonPadding": "calc({spacing.base} * 3)",
      "inputPadding": "calc({spacing.base} * 3)",
      "listItemSpacing": "calc({spacing.base} * 3)",
      "chartPadding": "calc({spacing.base} * 4)"
    }
  },
  "borderRadius": {
    "none": "0",
    "xs": "4",
    "sm": "8",
    "md": "12",
    "lg": "16",
    "xl": "24",
    "full": "9999"
  },
  "elevation": {
    "none": {
      "shadowColor": "transparent",
      "shadowOffset": {
        "width": 0,
        "height": 0
      },
      "shadowOpacity": 0,
      "shadowRadius": 0,
      "elevation": 0
    },
    "xs": {
      "shadowColor": "#000000",
      "shadowOffset": {
        "width": 0,
        "height": 1
      },
      "shadowOpacity": 0.05,
      "shadowRadius": 2,
      "elevation": 1
    },
    "sm": {
      "shadowColor": "#000000",
      "shadowOffset": {
        "width": 0,
        "height": 2
      },
      "shadowOpacity": 0.1,
      "shadowRadius": 4,
      "elevation": 2
    },
    "md": {
      "shadowColor": "#000000",
      "shadowOffset": {
        "width": 0,
        "height": 3
      },
      "shadowOpacity": 0.15,
      "shadowRadius": 6,
      "elevation": 3
    }
  },
  "components": {
    "card": {
      "borderRadius": "{borderRadius.lg}",
      "padding": "{spacing.layout.cardPadding}",
      "elevation": "{elevation.sm}",
      "backgroundColor": "{colors.light.surface}"
    },
    "chart": {
      "padding": "{spacing.layout.chartPadding}",
      "borderRadius": "{borderRadius.lg}",
      "gridColor": "{colors.palette.gray.200}",
      "labelColor": "{colors.palette.gray.500}"
    },
    "progressRing": {
      "thickness": "8",
      "size": {
        "small": "64",
        "medium": "96",
        "large": "128"
      }
    },
    "nutritionBar": {
      "height": "8",
      "borderRadius": "{borderRadius.full}",
      "spacing": "{spacing.scale.xs}"
    },
    "listItem": {
      "height": "72",
      "padding": "{spacing.layout.listItemSpacing}",
      "borderRadius": "{borderRadius.md}"
    }
  }
} 